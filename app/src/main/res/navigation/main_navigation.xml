<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_navigation"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="id.co.iconpln.controlflowapp.fragmentsNavComponent.HomeNavFragment"
        android:label="fragment_home"
        tools:layout="@layout/fragment_home_nav">
        <action
            android:id="@+id/action_homeFragment_to_otherFragment"
            app:destination="@id/otherFragment" />
        <action
            android:id="@+id/action_homeFragment_to_styleActivity"
            app:destination="@id/styleActivity" />
    </fragment>

    <fragment
        android:id="@+id/otherFragment"
        android:name="id.co.iconpln.controlflowapp.fragments.OtherFragment"
        android:label="fragment_other"
        tools:layout="@layout/fragment_other" />

    <activity
        android:id="@+id/styleActivity"
        android:name="id.co.iconpln.controlflowapp.StyleActivity"
        android:label="activity_style"
        tools:layout="@layout/activity_style" />

</navigation>
