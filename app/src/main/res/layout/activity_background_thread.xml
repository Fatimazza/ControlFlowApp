<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    tools:context=".BackgroundThreadActivity">

    <TextView
        android:id="@+id/tvThreadWorkerResult"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:gravity="center"
        android:text="Worker Thread Result" />

    <Button
        android:id="@+id/btnThreadWorker"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Worker Thread" />

    <TextView
        android:id="@+id/tvThreadHandlerResult"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:gravity="center"
        android:text="Handler Result" />

    <Button
        android:id="@+id/btnThreadHandler"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Handler" />

    <TextView
        android:id="@+id/tvThreadAsyncResult"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:gravity="center"
        android:text="Async Task Result" />

    <ProgressBar
        android:id="@+id/pbThreadAsyncProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnThreadAsyncTask"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Async Task" />

    <TextView
        android:id="@+id/tvThreadExecutorResult"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:gravity="center"
        android:text="Executor Result" />

    <Button
        android:id="@+id/btnThreadExecutor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Executor" />

    <TextView
        android:id="@+id/tvThreadCoroutineResult"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:gravity="center"
        android:text="Coroutine Result" />

    <Button
        android:id="@+id/btnThreadCoroutine"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Coroutine" />

    <TextView
        android:id="@+id/tvThreadCoroutineNewResult"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:gravity="center"
        android:text="Coroutine New Result" />

    <Button
        android:id="@+id/btnThreadCoroutineNew"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Coroutine New" />

</LinearLayout>
